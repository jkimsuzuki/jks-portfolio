<div class="journal-page">

  <div class="journal-top-row">
    <div class="journal-title panel">
      <p class="section-title">// JOURNAL.EXE</p>
      <h2 class="journal-heading">Capture thoughts. Track growth.</h2>
      <p class="journal-subtext">Daily reflections, ideas, lessons learned, and plans to keep improving — one entry at a time.</p>
    </div>
    <div class="journal-stats panel">
      <div class="journal-stat">
        <p class="journal-stat-label">TOTAL ENTRIES</p>
        <p class="journal-stat-value"><%= @entries.count %></p>
        <p class="journal-stat-sub">All time</p>
      </div>
      <div class="journal-stat">
        <p class="journal-stat-label">THIS MONTH</p>
        <p class="journal-stat-value"><%= @entries.where(entry_date: Date.current.beginning_of_month..Date.current.end_of_month).count %></p>
        <p class="journal-stat-sub">Entries</p>
      </div>
    </div>
  </div>

  <div class="journal-filter-row">
    <div class="journal-filters">
      <a href="#" class="filter-tab filter-active">ALL</a>
      <a href="#" class="filter-tab">REFLECTION</a>
      <a href="#" class="filter-tab">IDEA</a>
      <a href="#" class="filter-tab">PLAN</a>
      <a href="#" class="filter-tab">LESSON</a>
      <a href="#" class="filter-tab">NOTE</a>
    </div>
    <div class="experiments-search">
      <input type="text" class="search-input" placeholder="Search journal...">
    </div>
  </div>

  <div class="journal-main-row">

    <div class="journal-list-col">

      <%= form_with model: @new_entry, url: journal_entries_path, class: "new-entry-form panel" do |f| %>
        <p class="section-title">// NEW ENTRY</p>
        <div class="new-entry-fields">
          <%= f.text_field :title, placeholder: "Entry title", class: "entry-input" %>
          <%= f.select :entry_type, %w[REFLECTION IDEA PLAN LESSON NOTE], {}, class: "entry-input entry-select" %>
          <%= f.text_field :tags, placeholder: "Tags (comma separated)", class: "entry-input" %>
          <%= f.date_field :entry_date, class: "entry-input", value: Date.today %>
        </div>
        <%= f.text_area :body, placeholder: "Write your entry here...", class: "entry-input entry-textarea" %>
        <%= f.submit "+ Add Entry", class: "entry-submit" %>
      <% end %>

      <% if @entries.any? %>
        <% @entries.group_by { |e| e.entry_date }.each do |date, entries| %>
          <p class="journal-date-group"><%= date&.strftime("%B %d, %Y") || "No date" %></p>
          <% entries.each do |entry| %>
            <div class="journal-entry">
              <div class="journal-entry-icon entry-icon-<%= entry.entry_type.downcase %>">
                <%= entry.entry_type.first %>
              </div>
              <div class="journal-entry-body">
                <div class="journal-entry-header">
                  <p class="journal-entry-title"><%= entry.title %></p>
                  <span class="tag tag-<%= entry.entry_type.downcase %>"><%= entry.entry_type %></span>
                  <span class="journal-entry-date"><%= entry.entry_date&.strftime("%b %d, %Y") %></span>
                </div>
                <% if entry.body.present? %>
                  <p class="journal-entry-desc"><%= entry.body %></p>
                <% end %>
                <% if entry.tag_list.any? %>
                  <div class="journal-entry-tags">
                    <% entry.tag_list.each do |tag| %>
                      <span class="journal-tag"><%= tag %></span>
                    <% end %>
                  </div>
                <% end %>
              </div>
              <%= button_to "×", journal_entry_path(entry), method: :delete, class: "entry-delete", data: { turbo_confirm: "Delete this entry?" } %>
            </div>
          <% end %>
        <% end %>
      <% else %>
        <p class="journal-empty">No entries yet. Add your first one above.</p>
      <% end %>

    </div>

    <div class="journal-right-col">

      <div class="journal-calendar panel">
        <div class="calendar-header">
          <p class="section-title">CALENDAR VIEW</p>
          <div class="calendar-nav">
            <span class="cal-nav">‹</span>
            <span class="cal-month"><%= Date.today.strftime("%B %Y") %></span>
            <span class="cal-nav">›</span>
          </div>
        </div>
        <% entry_dates = @entries.pluck(:entry_date).compact.map(&:to_date) %>
        <% today = Date.today %>
        <% first_day = today.beginning_of_month %>
        <% last_day = today.end_of_month %>
        <table class="calendar-table">
          <thead>
            <tr>
              <th>Su</th><th>Mo</th><th>Tu</th><th>We</th><th>Th</th><th>Fr</th><th>Sa</th>
            </tr>
          </thead>
          <tbody>
            <% week_start = first_day.beginning_of_week(:sunday) %>
            <% while week_start <= last_day %>
              <tr>
                <% 7.times do |i| %>
                  <% day = week_start + i %>
                  <% if day.month == today.month %>
                    <% classes = ["cal-day"] %>
                    <% classes << "cal-today" if day == today %>
                    <% classes << "cal-has-entry" if entry_dates.include?(day) %>
                    <td class="<%= classes.join(' ') %>"><%= day.day %></td>
                  <% else %>
                    <td></td>
                  <% end %>
                <% end %>
              </tr>
              <% week_start += 7 %>
            <% end %>
          </tbody>
        </table>
      </div>

      <div class="journal-recent-tags panel">
        <p class="section-title">RECENTLY USED TAGS</p>
        <div class="recent-tags-list">
          <% all_tags = @entries.flat_map(&:tag_list).tally.sort_by { |_, count| -count }.first(12) %>
          <% if all_tags.any? %>
            <% all_tags.each do |tag, _| %>
              <span class="journal-tag"><%= tag %></span>
            <% end %>
          <% else %>
            <span class="journal-tag-empty">No tags yet</span>
          <% end %>
        </div>
      </div>

    </div>

  </div>

</div>
