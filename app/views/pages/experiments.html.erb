<div class="experiments-page">

  <div class="experiments-top-row">
    <div class="experiments-title panel">
      <p class="section-title">// EXPERIMENTS.EXE</p>
      <h2 class="experiments-heading">Active experiments. Real learning.</h2>
      <p class="experiments-subtext">Building, testing, and iterating on ideas that drive growth and solve real problems.</p>
    </div>
    <div class="experiments-stats panel">
      <div class="exp-stat">
        <p class="exp-stat-label">ACTIVE EXPERIMENTS</p>
        <p class="exp-stat-value"><%= @experiments.where(status: "IN PROGRESS").count %></p>
        <p class="exp-stat-sub">In progress</p>
      </div>
      <div class="exp-stat">
        <p class="exp-stat-label">COMPLETED</p>
        <p class="exp-stat-value"><%= @experiments.where(status: "COMPLETE").count %></p>
        <p class="exp-stat-sub">Shipped</p>
      </div>
      <div class="exp-stat">
        <p class="exp-stat-label">IDEAS BACKLOG</p>
        <p class="exp-stat-value"><%= @experiments.where(status: "IDEA").count %></p>
        <p class="exp-stat-sub">Planned</p>
      </div>
      <div class="exp-stat">
        <p class="exp-stat-label">TOTAL</p>
        <p class="exp-stat-value"><%= @experiments.count %></p>
        <p class="exp-stat-sub">All time</p>
      </div>
    </div>
  </div>

  <div class="experiments-filter-row">
    <div class="experiments-filters">
      <a href="#" class="filter-tab filter-active">ALL</a>
      <a href="#" class="filter-tab">IN PROGRESS</a>
      <a href="#" class="filter-tab">COMPLETE</a>
      <a href="#" class="filter-tab">IDEA</a>
      <a href="#" class="filter-tab">ON HOLD</a>
    </div>
    <div class="experiments-search">
      <input type="text" class="search-input" placeholder="Search experiments...">
    </div>
  </div>

  <div class="experiments-main-row">

    <div class="experiments-list-col">

      <%= form_with model: @new_experiment, url: experiments_path, class: "new-entry-form panel" do |f| %>
        <p class="section-title">// NEW EXPERIMENT</p>
        <div class="new-entry-fields">
          <%= f.text_field :name, placeholder: "Experiment name", class: "entry-input" %>
          <%= f.select :status, ["IN PROGRESS", "COMPLETE", "IDEA", "ON HOLD"], {}, class: "entry-input entry-select" %>
          <%= f.date_field :experiment_date, class: "entry-input", value: Date.today %>
        </div>
        <%= f.text_area :description, placeholder: "What is this experiment about?", class: "entry-input entry-textarea" %>
        <%= f.text_field :url, placeholder: "URL (optional — GitHub, live link)", class: "entry-input" %>
        <%= f.submit "+ Add Experiment", class: "entry-submit" %>
      <% end %>

      <% if @experiments.any? %>
        <% @experiments.each_with_index do |experiment, index| %>
          <div class="exp-item">
            <span class="exp-num">(<%= "%02d" % (index + 1) %>)</span>
            <div class="exp-thumbnail exp-thumb-<%= experiment.status.downcase.gsub(' ', '-') %>"></div>
            <div class="exp-details">
              <div class="exp-title-row">
                <% if experiment.url.present? %>
                  <a href="<%= experiment.url %>" target="_blank" class="exp-name"><%= experiment.name %></a>
                <% else %>
                  <p class="exp-name"><%= experiment.name %></p>
                <% end %>
                <span class="tag tag-<%= experiment.status.downcase.gsub(' ', '-') %>"><%= experiment.status %></span>
              </div>
              <p class="exp-desc"><%= experiment.description %></p>
            </div>
            <div class="exp-meta">
              <p class="exp-meta-label"><%= experiment.status == "COMPLETE" ? "COMPLETED" : "UPDATED" %></p>
              <p class="exp-meta-date"><%= experiment.experiment_date&.strftime("%b %Y") %></p>
            </div>
            <%= button_to "×", experiment_path(experiment), method: :delete, class: "entry-delete", data: { turbo_confirm: "Delete this experiment?" } %>
          </div>
        <% end %>
      <% else %>
        <p class="journal-empty">No experiments yet. Add your first one above.</p>
      <% end %>

      <div class="tip-bar">
        <span class="tip-star">✳</span>
        <span class="tip-label"> TIP </span>
        <span class="tip-text">Document learnings in </span>
        <a href="/journal" class="tip-link">journal.exe</a>
        <span class="tip-text"> and track insights in </span>
        <a href="/learnings" class="tip-link">learnings.exe</a>
      </div>

    </div>

    <div class="experiments-right-col">

      <div class="exp-summary panel">
        <p class="section-title">EXPERIMENT SUMMARY</p>
        <% total = @experiments.count.to_f %>
        <% in_progress = @experiments.where(status: "IN PROGRESS").count %>
        <% complete = @experiments.where(status: "COMPLETE").count %>
        <% idea = @experiments.where(status: "IDEA").count %>
        <% on_hold = @experiments.where(status: "ON HOLD").count %>
        <div class="donut-wrap">
          <div class="donut-chart" style="background: conic-gradient(
            var(--c-in-progress) 0% <%= total > 0 ? (in_progress / total * 100).round : 0 %>%,
            var(--c-support) <%= total > 0 ? (in_progress / total * 100).round : 0 %>% <%= total > 0 ? ((in_progress + complete) / total * 100).round : 0 %>%,
            var(--c-idea) <%= total > 0 ? ((in_progress + complete) / total * 100).round : 0 %>% <%= total > 0 ? ((in_progress + complete + idea) / total * 100).round : 0 %>%,
            var(--fg-dim) <%= total > 0 ? ((in_progress + complete + idea) / total * 100).round : 0 %>% 100%
          );">
            <div class="donut-hole">
              <p class="donut-total"><%= @experiments.count %></p>
              <p class="donut-label">Total</p>
            </div>
          </div>
          <div class="donut-legend">
            <div class="legend-item">
              <span class="legend-dot legend-progress"></span>
              <span class="legend-name">In Progress</span>
              <span class="legend-count"><%= in_progress %></span>
            </div>
            <div class="legend-item">
              <span class="legend-dot legend-complete"></span>
              <span class="legend-name">Complete</span>
              <span class="legend-count"><%= complete %></span>
            </div>
            <div class="legend-item">
              <span class="legend-dot legend-idea"></span>
              <span class="legend-name">Idea</span>
              <span class="legend-count"><%= idea %></span>
            </div>
            <div class="legend-item">
              <span class="legend-dot legend-hold"></span>
              <span class="legend-name">On Hold</span>
              <span class="legend-count"><%= on_hold %></span>
            </div>
          </div>
        </div>
      </div>

      <div class="exp-activity panel">
        <p class="section-title">RECENT ACTIVITY</p>
        <% @experiments.first(5).each do |experiment| %>
          <div class="activity-item">
            <span class="activity-date"><%= experiment.experiment_date&.strftime("%b %Y") %></span>
            <span class="activity-text"><%= experiment.status == "COMPLETE" ? "Completed" : "Updated" %>: <%= experiment.name %></span>
          </div>
        <% end %>
        <% if @experiments.empty? %>
          <p class="journal-empty">No activity yet.</p>
        <% end %>
      </div>

      <div class="exp-quick-actions panel">
        <p class="section-title">QUICK ACTIONS</p>
        <a href="https://innocent-elinore-josephkim-suzuki-1e11ded2.koyeb.app/" target="_blank" class="quick-action-item">
          <span class="quick-action-icon">▶</span>
          <span>View SignalDesk</span>
        </a>
        <a href="https://github.com/jkimsuzuki" target="_blank" class="quick-action-item">
          <span class="quick-action-icon">◈</span>
          <span>View GitHub</span>
        </a>
        <a href="/journal" class="quick-action-item">
          <span class="quick-action-icon">◉</span>
          <span>View Journal</span>
        </a>
      </div>

    </div>

  </div>

</div>
