<div class="learnings-page">

  <div class="learnings-top-row">
    <div class="learnings-title panel">
      <p class="section-title">// LEARNINGS.EXE</p>
      <h2 class="learnings-heading">Learn continuously. Level up.</h2>
      <p class="learnings-subtext">Curated resources, notes, and insights to build expertise and stay sharp.</p>
    </div>
    <div class="learnings-stats panel">
      <div class="learning-stat">
        <p class="learning-stat-label">TOTAL RESOURCES</p>
        <p class="learning-stat-value"><%= @learnings.count %></p>
        <p class="learning-stat-sub">Curated</p>
      </div>
      <div class="learning-stat">
        <p class="learning-stat-label">COMPLETED</p>
        <p class="learning-stat-value"><%= @learnings.where(progress: 100).count %></p>
        <p class="learning-stat-sub"><%= @learnings.count > 0 ? "#{(@learnings.where(progress: 100).count.to_f / @learnings.count * 100).round}% complete" : "0% complete" %></p>
      </div>
      <div class="learning-stat">
        <p class="learning-stat-label">IN PROGRESS</p>
        <p class="learning-stat-value"><%= @learnings.where.not(progress: 100).count %></p>
        <p class="learning-stat-sub">Active</p>
      </div>
      <div class="learning-stat">
        <p class="learning-stat-label">TOPICS</p>
        <p class="learning-stat-value"><%= @learnings.pluck(:topic).compact.uniq.count %></p>
        <p class="learning-stat-sub">Areas</p>
      </div>
    </div>
  </div>

  <div class="learnings-filter-row">
    <div class="learnings-filters">
      <a href="#" class="filter-tab filter-active">ALL</a>
      <a href="#" class="filter-tab">COURSES</a>
      <a href="#" class="filter-tab">DOCUMENTATION</a>
      <a href="#" class="filter-tab">VIDEOS</a>
      <a href="#" class="filter-tab">ARTICLES</a>
      <a href="#" class="filter-tab">BOOKS</a>
      <a href="#" class="filter-tab">NOTES</a>
    </div>
    <div class="experiments-search">
      <input type="text" class="search-input" placeholder="Search learnings...">
      <span class="filter-btn">⧉ FILTERS</span>
    </div>
  </div>

  <div class="learnings-main-row">

    <div class="learnings-list-col">

      <%= form_with model: @new_learning, url: learnings_path, class: "new-entry-form panel" do |f| %>
        <p class="section-title">// NEW RESOURCE</p>
        <div class="new-entry-fields">
          <%= f.text_field :name, placeholder: "Resource name", class: "entry-input" %>
          <%= f.select :resource_type, %w[COURSE DOCUMENTATION VIDEO ARTICLE BOOK NOTE], {}, class: "entry-input entry-select" %>
          <%= f.text_field :topic, placeholder: "Topic (e.g. RAILS, SHOPIFY)", class: "entry-input" %>
          <%= f.number_field :progress, placeholder: "Progress (0-100)", min: 0, max: 100, class: "entry-input entry-select" %>
        </div>
        <%= f.text_area :description, placeholder: "What is this resource about?", class: "entry-input entry-textarea" %>
        <%= f.text_field :url, placeholder: "URL (optional)", class: "entry-input" %>
        <%= f.submit "+ Add Resource", class: "entry-submit" %>
      <% end %>

      <% if @learnings.any? %>
        <% @learnings.each_with_index do |learning, index| %>
          <div class="learning-item">
            <span class="learning-num">(<%= "%02d" % (index + 1) %>)</span>
            <div class="learning-icon learning-icon-<%= learning.resource_type.downcase %>">
              <%= learning.name.split.map(&:first).first(2).join.upcase %>
            </div>
            <div class="learning-details">
              <div class="learning-title-row">
                <% if learning.url.present? %>
                  <a href="<%= learning.url %>" target="_blank" class="learning-name"><%= learning.name %></a>
                <% else %>
                  <p class="learning-name"><%= learning.name %></p>
                <% end %>
                <span class="tag tag-<%= learning.resource_type.downcase %>"><%= learning.resource_type %></span>
                <% if learning.topic.present? %>
                  <span class="tag tag-topic"><%= learning.topic %></span>
                <% end %>
              </div>
              <% if learning.description.present? %>
                <p class="learning-desc"><%= learning.description %></p>
              <% end %>
              <div class="learning-progress-bar">
                <div class="learning-progress-fill <%= learning.complete? ? 'learning-progress-complete' : '' %>" style="width: <%= learning.progress || 0 %>%"></div>
              </div>
            </div>
            <div class="learning-meta">
              <p class="learning-meta-pct <%= learning.complete? ? 'learning-complete-pct' : '' %>"><%= learning.progress || 0 %>%</p>
              <p class="learning-meta-sub"><%= learning.complete? ? "Complete" : "In progress" %></p>
            </div>
            <%= button_to "×", learning_path(learning), method: :delete, class: "entry-delete", data: { turbo_confirm: "Delete this resource?" } %>
          </div>
        <% end %>
      <% else %>
        <p class="journal-empty">No resources yet. Add your first one above.</p>
      <% end %>

      <div class="learning-footer">
        <a href="#" class="view-all-link">> view all learnings</a>
      </div>

    </div>

    <div class="learnings-right-col">

      <div class="learning-streak panel">
        <p class="section-title">LEARNING STREAK</p>
        <div class="streak-header">
          <span class="streak-count">🔥 — days</span>
          <span class="streak-encourage">Keep it up!</span>
        </div>
        <div class="streak-week">
          <% %w[M T W T F S S].each_with_index do |day, i| %>
            <div class="streak-day-col">
              <span class="streak-dot <%= i < 5 ? 'streak-active' : i == 5 ? 'streak-today' : 'streak-future' %>"><%= i < 5 ? '✓' : '' %></span>
              <span class="streak-day-label"><%= day %></span>
            </div>
          <% end %>
        </div>
        <p class="streak-longest">Longest streak: — days</p>
      </div>

      <div class="top-categories panel">
        <p class="section-title">TOP CATEGORIES</p>
        <% topic_counts = @learnings.pluck(:topic).compact.tally.sort_by { |_, c| -c } %>
        <% max_count = topic_counts.first&.last.to_f %>
        <% if topic_counts.any? %>
          <% topic_counts.first(5).each do |topic, count| %>
            <div class="category-item">
              <span class="category-name"><%= topic %></span>
              <div class="category-bar">
                <div class="category-fill" style="width: <%= max_count > 0 ? (count / max_count * 100).round : 0 %>%"></div>
              </div>
              <span class="category-count"><%= count %></span>
            </div>
          <% end %>
        <% else %>
          <p class="journal-empty">No topics yet.</p>
        <% end %>
      </div>

    </div>

  </div>

</div>
